# Copy to .env.local for local development (never commit secrets)

# Halo PSA — create an API client in Halo: Admin > Integrations > API
HALO_CLIENT_ID=your-halo-client-id
HALO_CLIENT_SECRET=your-halo-client-secret

# Halo asset status IDs — check yours in Halo: Admin > Assets > Statuses
HALO_STATUS_AVAILABLE=1
HALO_STATUS_IN_USE=2

# Entra / Azure AD — register an app in portal.azure.com
ENTRA_CLIENT_ID=your-entra-app-client-id
ENTRA_CLIENT_SECRET=your-entra-app-client-secret
# YOUR_TENANT_ID — replace in staticwebapp.config.json too
