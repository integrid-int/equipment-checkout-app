{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deployment Kit PWA — Azure Static Web App with Entra auth, Halo PSA integration, and role-based access"
  },
  "parameters": {
    "siteName": {
      "type": "string",
      "metadata": { "description": "Name for the Static Web App resource (must be globally unique)" },
      "minLength": 2,
      "maxLength": 40
    },
    "location": {
      "type": "string",
      "defaultValue": "eastus2",
      "allowedValues": [
        "centralus", "eastus2", "eastasia", "westeurope",
        "westus2", "southcentralus", "eastus", "northeurope"
      ],
      "metadata": { "description": "Azure region for the Static Web App and Storage Account" }
    },
    "sku": {
      "type": "string",
      "defaultValue": "Standard",
      "allowedValues": ["Free", "Standard"],
      "metadata": { "description": "Standard required for custom Entra authentication" }
    },
    "entraTenantId": {
      "type": "string",
      "metadata": { "description": "Azure AD / Entra tenant ID" }
    },
    "entraClientId": {
      "type": "string",
      "metadata": { "description": "Entra app registration client ID" }
    },
    "entraClientSecret": {
      "type": "securestring",
      "metadata": { "description": "Entra app registration client secret" }
    },
    "haloClientId": {
      "type": "string",
      "metadata": { "description": "Halo PSA API client ID (Admin → Integrations → API)" }
    },
    "haloClientSecret": {
      "type": "securestring",
      "metadata": { "description": "Halo PSA API client secret" }
    },
    "adminEmails": {
      "type": "string",
      "metadata": { "description": "Comma-separated email addresses that are always admins (bootstraps first admin)" }
    }
  },
  "variables": {
    "issuerUrl": "[concat('https://login.microsoftonline.com/', parameters('entraTenantId'), '/v2.0')]",
    "storageAccountName": "[concat('kitstorage', uniqueString(resourceGroup().id))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-01-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/tableServices/tables",
      "apiVersion": "2023-01-01",
      "name": "[concat(variables('storageAccountName'), '/default/userroles')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/staticSites",
      "apiVersion": "2023-01-01",
      "name": "[parameters('siteName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "[parameters('sku')]",
        "tier": "[parameters('sku')]"
      },
      "properties": {
        "enterpriseGradeCdnStatus": "Disabled"
      }
    },
    {
      "type": "Microsoft.Web/staticSites/config",
      "apiVersion": "2023-01-01",
      "name": "[concat(parameters('siteName'), '/appsettings')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/staticSites', parameters('siteName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "HALO_CLIENT_ID": "[parameters('haloClientId')]",
        "HALO_CLIENT_SECRET": "[parameters('haloClientSecret')]",
        "ENTRA_CLIENT_ID": "[parameters('entraClientId')]",
        "ENTRA_CLIENT_SECRET": "[parameters('entraClientSecret')]",
        "ENTRA_TENANT_ID": "[parameters('entraTenantId')]",
        "ENTRA_ISSUER_URL": "[variables('issuerUrl')]",
        "ADMIN_EMAILS": "[parameters('adminEmails')]",
        "AZURE_STORAGE_CONNECTION_STRING": "[concat('DefaultEndpointsProtocol=https;AccountName=', variables('storageAccountName'), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-01-01').keys[0].value, ';EndpointSuffix=core.windows.net')]"
      }
    }
  ],
  "outputs": {
    "swaUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/staticSites', parameters('siteName'))).defaultHostname)]"
    },
    "entraRedirectUri": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.Web/staticSites', parameters('siteName'))).defaultHostname, '/.auth/login/aad/callback')]"
    },
    "storageAccountName": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    }
  }
}
